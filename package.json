{
    "name": "out-e2e-playwright",
    "version": "1.0.0",
    "description": "Projeto de testes com Playwright",
    "main": "index.js",
    "scripts": {
        "lint": "npx eslint . --ext .ts",
        "playwright:open": "npx playwright test --ui",
        "playwright:test": "npx playwright test",
        "playwright:api": "npx playwright test tests/api/",
        "playwright:e2e": "npx playwright test tests/web/",
        "test": "npm run playwright:api && npm run playwright:e2e",
        "playwright:Report": "npx playwright show-report"
    },
